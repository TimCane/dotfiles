#!/bin/bash
# Rofi power menu with confirmation

options="⏻ Shutdown\n Reboot\n⏾ Suspend\n Lock\n Logout"

chosen=$(echo -e "$options" | rofi -dmenu -i -p "Power" -theme-str '
    window { width: 250px; }
    listview { lines: 5; }
')

confirm() {
    echo -e "Yes\nNo" | rofi -dmenu -i -p "$1?" -theme-str '
        window { width: 200px; }
        listview { lines: 2; }
    '
}

case "$chosen" in
    *Shutdown)
        [[ $(confirm "Shutdown") == "Yes" ]] && systemctl poweroff
        ;;
    *Reboot)
        [[ $(confirm "Reboot") == "Yes" ]] && systemctl reboot
        ;;
    *Suspend)
        systemctl suspend
        ;;
    *Lock)
        betterlockscreen -l
        ;;
    *Logout)
        [[ $(confirm "Logout") == "Yes" ]] && i3-msg exit
        ;;
esac
